# Variables de entorno para la aplicación
# Copia este archivo como .env y configura tus valores

# Puerto del servidor
PORT=3000

# Configuración de la base de datos MariaDB
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=login_db
DB_PORT=3306

# Clave secreta para las sesiones (CAMBIA ESTO por algo seguro)
SESSION_SECRET=tu_clave_super_secreta_aqui

# Entorno de la aplicación (development/production)
NODE_ENV=development